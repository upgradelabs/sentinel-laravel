{
    "name": "upgradelabs/sentinel-laravel",
    "description": "Laravel error reporting client for Sentinel. Captures exceptions and sends them to your Sentinel dashboard.",
    "keywords": ["laravel", "error-tracking", "sentinel", "logging", "exceptions"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^7.4|^8.0",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^1.0|^2.0|^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "UpgradeLabs\\SentinelLaravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "UpgradeLabs\\SentinelLaravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "UpgradeLabs\\SentinelLaravel\\SentinelServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
